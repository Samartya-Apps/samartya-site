---
---
<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <span class="brand-text">Samartya Apps</span>
        <p class="brand-desc">Building evidence-based tools that help children with autism, dyslexia, and language disabilities learn to communicate, read, and thrive.</p>
        <div class="social-links">
          <a href="#">Facebook</a>
          <a href="#">Instagram</a>
          <a href="#">LinkedIn</a>
          <a href="#">YouTube</a>
        </div>
      </div>
      
      <div class="footer-links">
        <div class="link-col">
          <h3>Products</h3>
          <ul>
            <li><a href="/freespeech">FreeSpeech</a></li>
            <li><a href="/dyslexia-reader">Dyslexia Reader</a></li>
          </ul>
        </div>
        <div class="link-col">
          <h3>Company</h3>
          <ul>
            <li><a href="/about">About</a></li>
            <li><a href="/research">Research</a></li>
            <li><a href="/blog">Blog</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>
        <div class="link-col">
          <h3>Legal</h3>
          <ul>
            <li><a href="/privacy">Privacy Policy</a></li>
            <li><a href="/terms">Terms of Use</a></li>
          </ul>
        </div>
      </div>
    </div>
    
    <div class="footer-bottom">
      <div class="badges">
        <!-- Placeholders for App Store and Google Play -->
        <span class="badge"> App Store</span>
        <span class="badge">▶ Google Play</span>
      </div>
      <p class="copyright">&copy; {new Date().getFullYear()} Samartya Apps. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-bg-surface);
    border-top: 1px solid var(--color-border);
    padding: var(--spacing-16) 0 var(--spacing-8);
    margin-top: var(--spacing-16);
  }
  
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-8);
    margin-bottom: var(--spacing-12);
  }
  
  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 1.5fr 2fr;
    }
  }
  
  .brand-text {
    font-family: var(--font-family-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-primary-dark);
    display: block;
    margin-bottom: var(--spacing-4);
  }
  
  .brand-desc {
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-6);
    max-width: 400px;
  }
  
  .social-links {
    display: flex;
    gap: var(--spacing-4);
  }
  
  .social-links a {
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }
  
  .social-links a:hover {
    color: var(--color-primary);
  }
  
  .footer-links {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-8);
  }
  
  @media (min-width: 480px) {
    .footer-links {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  
  .link-col h3 {
    font-size: 1rem;
    margin-bottom: var(--spacing-4);
    color: var(--color-text-main);
  }
  
  .link-col li {
    margin-bottom: var(--spacing-2);
  }
  
  .link-col a {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }
  
  .link-col a:hover {
    color: var(--color-primary);
  }
  
  .footer-bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-6);
    border-top: 1px solid var(--color-border);
    padding-top: var(--spacing-8);
  }
  
  @media (min-width: 768px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }
  
  .badges {
    display: flex;
    gap: var(--spacing-4);
  }
  
  .badge {
    background: var(--color-text-main);
    color: white;
    padding: var(--spacing-2) var(--spacing-4);
    border-radius: var(--border-radius-md);
    font-size: 0.875rem;
    font-weight: 500;
  }
  
  .copyright {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin: 0;
  }
</style>
