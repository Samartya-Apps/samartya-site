---
interface Props {
  title?: string;
  image?: string;
  icon?: string;
}

const { title, image, icon } = Astro.props;
---

<div class="card basic-card">
  {
    image && (
      <div class="card-image-wrap">
        <img src={image} alt={title || "Card visual"} class="card-img" />
      </div>
    )
  }
  {
    icon && (
      <div class="card-icon">
        <img src={icon} alt="" width="128" height="128" />
      </div>
    )
  }
  <div class="card-content">
    {title && <h3 class="card-title">{title}</h3>}
    <slot />
  </div>
</div>

<style>
  .basic-card {
    height: 100%;
    display: flex;
    flex-direction: column;
    padding: 0;
    overflow: hidden;
  }

  .card-image-wrap {
    width: 100%;
    height: 200px;
    background: var(--color-bg-alt);
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid var(--color-border);
  }

  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-icon {
    padding: var(--spacing-6) var(--spacing-6) 0;
  }

  .card-icon img {
    border-radius: 16px;
  }

  .card-content {
    padding: var(--spacing-6);
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .card-title {
    margin-bottom: var(--spacing-2);
  }

  /* Give the content area the ability to space its children nicely */
  .card-content :global(p) {
    color: var(--color-text-muted);
    flex-grow: 1;
    margin-bottom: var(--spacing-4);
  }
</style>
