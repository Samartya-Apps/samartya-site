---
import Layout from '../layouts/Layout.astro';
import AppCard from '../components/AppCard.astro';
// Removed 'import { Icon } from "astro-icon";'
---

<Layout title="Samartya - Apps for Better Learning and Communication">
	<main class="max-w-4xl mx-auto p-4 md:p-8">
		<header class="text-center mb-12">
			<h1 class="text-5xl font-extrabold text-indigo-700 mb-4">
				Samartya
			</h1>
			<p class="text-xl text-gray-600">
				Empowering communication and learning through simple, effective mobile applications.
			</p>
		</header>

		<section class="mb-16">
			<h2 class="text-3xl font-semibold text-gray-800 mb-6 border-b pb-2">Our Apps</h2>
			<div class="grid md:grid-cols-2 gap-8">
				
				<AppCard
					title="Dyslexia Reader"
					description="A focused reading tool designed to enhance clarity and comprehension for users with dyslexia."
					appStoreLink="https://www.dyslexiareader.com"
					playStoreLink="https://www.dyslexiareader.com"
				/>

				<AppCard
					title="FreeSpeech"
					description="A simple, distraction-free app to help practice and improve speech articulation and fluency."
					appStoreLink="https://www.freespeechapp.com"
					playStoreLink="https://www.freespeechapp.com"
				/>

			</div>
		</section>

		<footer class="text-center text-sm text-gray-500 pt-8 border-t">
			<p>&copy; {new Date().getFullYear()} Samartya. All rights reserved.</p>
			<p class="mt-2">
				<a href="/delete-account" class="text-indigo-600 hover:underline">Request Account Deletion</a>
			</p>
		</footer>

	</main>
</Layout>