---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import Testimonial from '../components/Testimonial.astro';
---

<Layout 
  title="Samartya Apps — Language & Reading Apps for Children with Disabilities" 
  description="Evidence-based apps for children with autism, dyslexia, and language disorders. FreeSpeech teaches grammar through pictures. Dyslexia Reader makes classroom reading accessible.">

  <Hero 
    title="Every child deserves the power of language."
    subtitle="Samartya Apps builds evidence-based tools that help children with autism, dyslexia, and language disabilities learn to communicate, read, and thrive. Used by therapists, teachers, and families across the US and India."
    align="left"
    variant="primary"
  >
    <Fragment slot="actions">
      <Button href="/freespeech">Explore FreeSpeech</Button>
      <Button href="/dyslexia-reader" variant="outline">Explore Dyslexia Reader</Button>
    </Fragment>
    <Fragment slot="visual">
      <div class="video-placeholder">
        <!-- Placeholder for background video/hero image as specified by user -->
        <div class="box">Child using app with therapist</div>
      </div>
    </Fragment>
  </Hero>

  <section class="section section-light">
    <div class="container text-center">
      <h2>Two apps. One mission: unlocking language.</h2>
      <div class="product-cards">
        <Card title="FreeSpeech" icon="/img/freespeech-icon.png">
          <strong>Teach grammar through pictures.</strong>
          <p>Children drag and drop visual tiles to build sentences — and FreeSpeech converts them into grammatically correct English. The only app of its kind, FreeSpeech makes the invisible rules of grammar visible and interactive.</p>
          <ul class="features-list text-left">
            <li><strong>Designed for:</strong> Children with autism, language disorders, hearing impairments, and English language learners.</li>
            <li><strong>Used by:</strong> Speech-language pathologists, special educators, and parents.</li>
            <li><strong>Available on:</strong> iOS · Android</li>
          </ul>
          <div class="mt-auto">
            <Button href="/freespeech" variant="outline">Learn more →</Button>
          </div>
        </Card>

        <Card title="Dyslexia Reader" icon="/img/dyslexia-reader-icon.png">
          <strong>Make any reading material accessible.</strong>
          <p>Scan a physical page or upload a PDF — Dyslexia Reader digitizes it and adds powerful reading supports: text-to-speech, syllabification, onset/rime, dictionary, and more. Built on 20+ years of research.</p>
           <ul class="features-list text-left">
            <li><strong>Designed for:</strong> Children with dyslexia and reading difficulties.</li>
            <li><strong>Used by:</strong> Teachers, reading specialists, resource room coordinators, and parents.</li>
            <li><strong>Available on:</strong> iOS · Android · Web (coming soon)</li>
          </ul>
          <div class="mt-auto">
            <Button href="/dyslexia-reader" variant="outline">Learn more →</Button>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2 class="text-center mb-12">Built on research. Proven in classrooms.</h2>
      <div class="grid-3">
        <Card title="Research-Rooted">
          <p>FreeSpeech is based on original linguistic research that was the subject of a TED talk viewed over 1 million times. Dyslexia Reader draws on 20+ years of evidence-based strategies developed by the Madras Dyslexia Association.</p>
        </Card>
        <Card title="Designed for Educators">
          <p>Our apps are built in collaboration with speech-language pathologists, special educators, and researchers with over 100 years of collective experience. Every feature fits into real therapy sessions and classrooms.</p>
        </Card>
        <Card title="Accessible & Affordable">
          <p>Free to download and try. Subscription and one-time purchase options. Apple Volume Purchase Program (VPP) support with 50% off for 20+ school licenses.</p>
        </Card>
      </div>
    </div>
  </section>

  <section class="section section-light text-center">
    <div class="container">
      <h2 class="mb-12">The idea behind FreeSpeech</h2>
      <div class="video-embed-container">
        <!-- Placeholder for TED talk embed -->
        <div class="video-placeholder rounded">
          <div class="box">TED Talk Embed: Ajit Narayanan</div>
        </div>
      </div>
      <p class="max-w-m mx-auto mt-6">Ajit Narayanan's TED talk on the visual language system behind FreeSpeech has been viewed over 1 million times. The technology he describes is now available as an app used by therapists and educators worldwide.</p>
    </div>
  </section>

  <section class="section section-alt text-center">
    <div class="container">
      <h2 class="mb-8">Trusted by educators. Recognized worldwide.</h2>
      <div class="credibility-bar">
        <span>Featured by Apple as Best New App</span>
        <span>TED Talk — 1M+ views</span>
        <span>MIT Technology Review TR35 Innovator</span>
        <span>National Award from the President of India</span>
        <span>Built with Madras Dyslexia Association</span>
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container">
      <h2 class="text-center mb-12">Built for the people who support children every day.</h2>
      <div class="grid-3">
        <Card title="For SLPs & Therapists">
          <p>FreeSpeech integrates into your therapy sessions. Create custom challenges aligned to IEP goals, adjust vocabulary and grammar scaffolding levels, and track student progress — all within the app.</p>
          <a href="/freespeech/for-therapists">See how therapists use FreeSpeech →</a>
        </Card>
        <Card title="For Teachers & Schools">
          <p>Both apps work with your existing classroom materials. Dyslexia Reader turns your textbooks into accessible reading experiences. FreeSpeech supports language goals across subjects. Volume pricing makes it affordable.</p>
          <a href="/for-schools">See our school plans →</a>
        </Card>
        <Card title="For Parents & Families">
          <p>Give your child tools that work alongside their school support. Both apps are easy to use at home and designed to build independence over time.</p>
          <a href="/freespeech/for-parents">See how families use our apps →</a>
        </Card>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2 class="text-center mb-12">What educators and families are saying</h2>
      <div class="grid-3">
        <Testimonial 
          quote="I use this with my kids who have language disorders and this app goes very far in helping them expand their language. I love it and it is a very well designed app! Well worth any price!"
          author="Speech-Language Pathologist"
          role="App Store Review (FreeSpeech)"
        />
        <Testimonial 
          quote="Language structure made visual… What a wonderful way to help kids really 'see' language structure."
          author="Educator"
          role="App Store Review (FreeSpeech)"
        />
        <Testimonial 
          quote="It is probably the only app I've seen that actually makes it fun and stress-free to work with English sentences."
          author="Therapist"
          role="App Store Review (FreeSpeech)"
        />
      </div>
    </div>
  </section>

  <section class="section section-primary text-center">
    <div class="container">
      <h2 class="mb-6">Bring Samartya Apps to your school or district.</h2>
      <p class="mb-8">Free evaluation copies for AT specialists and SLPs. Volume pricing with Apple VPP (50% off for 20+ licenses). FERPA/COPPA compliant.</p>
      <div class="hero-actions">
        <Button href="/for-schools/request-trial" variant="secondary">Request a School Trial</Button>
        <Button href="/for-schools/pricing" variant="outline">See Pricing</Button>
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container text-center">
      <h2>Stay in the loop.</h2>
      <p class="mb-8 max-w-m mx-auto">Tips for therapists and teachers, product updates, and research insights — delivered monthly. No spam, ever.</p>
      <form class="newsletter-form">
        <input type="email" placeholder="Your email address" required class="input-field" />
        <Button variant="primary">Subscribe</Button>
      </form>
    </div>
  </section>

</Layout>

<style>
  .product-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-8);
    margin-top: var(--spacing-12);
  }

  @media (min-width: 768px) {
    .product-cards {
      grid-template-columns: 1fr 1fr;
    }
  }

  .grid-3 {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-8);
  }
  
  @media (min-width: 768px) {
    .grid-3 {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .features-list {
    margin-top: var(--spacing-4);
    margin-bottom: var(--spacing-6);
    font-size: 0.95rem;
  }
  
  .features-list li {
    margin-bottom: var(--spacing-2);
  }

  .mt-auto {
    margin-top: auto;
  }
  
  .text-left {
    text-align: left;
  }
  
  .mb-6 { margin-bottom: var(--spacing-6); }
  .mb-8 { margin-bottom: var(--spacing-8); }
  .mb-12 { margin-bottom: var(--spacing-12); }
  
  .max-w-m {
    max-width: 800px;
  }
  .mx-auto {
    margin-left: auto;
    margin-right: auto;
  }

  .video-placeholder {
    aspect-ratio: 16/9;
    background: var(--color-border);
    border-radius: var(--border-radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    color: var(--color-text-muted);
    font-weight: 600;
    max-width: 800px;
    margin: 0 auto;
  }

  .box {
    border: 2px dashed rgba(0, 0, 0, 0.2);
    padding: var(--spacing-8);
    border-radius: var(--border-radius-md);
  }

  .video-embed-container {
    margin-top: var(--spacing-8);
  }

  .rounded {
    border-radius: var(--border-radius-lg);
  }

  .credibility-bar {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--spacing-8);
    font-weight: 600;
    color: var(--color-text-muted);
  }
  
  .credibility-bar span {
    padding: var(--spacing-2) var(--spacing-4);
    background: var(--color-bg-surface);
    border-radius: var(--border-radius-full);
    box-shadow: var(--shadow-sm);
  }

  .section-primary {
    background-color: var(--color-primary-light);
  }

  .newsletter-form {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4);
    max-width: 500px;
    margin: 0 auto;
  }
  
  @media (min-width: 480px) {
    .newsletter-form {
      flex-direction: row;
    }
  }

  .input-field {
    flex-grow: 1;
    padding: var(--spacing-3) var(--spacing-4);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-full);
    font-family: inherit;
    font-size: 1rem;
    outline: none;
    transition: var(--transition-base);
  }

  .input-field:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px var(--color-primary-light);
  }
</style>