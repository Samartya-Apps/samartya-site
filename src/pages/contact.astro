---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Contact — Samartya Apps" 
  description="Get in touch with the Samartya Apps team for school evaluations, research collaborations, or support.">

  <section class="section section-light pt-24 pb-8">
    <div class="container max-w-m mx-auto text-center">
      <h1 class="mb-4">Get in Touch</h1>
      <p class="hero-subtitle">We'd love to hear from you. Reach out for support, institutional sales, or general inquiries.</p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container max-w-m mx-auto">
      <div class="form-container">
        <form
          id="contact-form"
          class="contact-form"
          action="https://api.web3forms.com/submit"
          method="POST"
        >
          <input type="hidden" name="access_key" value="dc5d701d-10d7-41c3-b56d-aefa709b456c" />
          <input type="hidden" name="subject" value="New contact message — samartya.com" />
          <input type="hidden" name="from_name" value="Samartya Contact Form" />
          <!-- Honeypot: humans leave it empty; bots fill it in -->
          <input type="checkbox" name="botcheck" class="hp-field" tabindex="-1" autocomplete="off" aria-hidden="true" />

          <div class="form-row">
            <div class="form-group flex-1">
              <label for="first-name">First Name *</label>
              <input type="text" id="first-name" name="first-name" required class="input-field" autocomplete="given-name" />
            </div>
            <div class="form-group flex-1">
              <label for="last-name">Last Name *</label>
              <input type="text" id="last-name" name="last-name" required class="input-field" autocomplete="family-name" />
            </div>
          </div>

          <div class="form-group">
            <label for="email">Email Address *</label>
            <input type="email" id="email" name="email" required class="input-field" autocomplete="email" />
          </div>

          <div class="form-group">
            <label for="topic">What can we help you with? *</label>
            <select id="topic" name="topic" required class="input-field">
              <option value="">Select a topic</option>
              <option value="schools">School Volume Purchasing & Quotes</option>
              <option value="support">App Support & Technical Issues</option>
              <option value="research">Research Collaboration</option>
              <option value="press">Press & Media</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div class="form-group">
            <label for="message">Your Message *</label>
            <textarea id="message" name="message" rows="6" required class="input-field"></textarea>
          </div>

          <div class="form-actions text-center mt-4">
            <button id="contact-submit" type="submit" class="btn btn-primary">Send Message</button>
          </div>

          <div id="contact-feedback" class="form-feedback" aria-live="polite"></div>
        </form>
      </div>
      
      <div class="contact-info mt-12 text-center">
        <h3>Other ways to reach us</h3>
        <p class="mt-4"><strong>For Schools & Institutions:</strong><br /> <a href="mailto:schools@samartya.com">schools@samartya.com</a></p>
        <p class="mt-4"><strong>General Support:</strong><br /> <a href="mailto:support@samartya.com">support@samartya.com</a></p>
      </div>
    </div>
  </section>

</Layout>

<style>
  .pt-24 { padding-top: var(--spacing-24); }
  .pb-8 { padding-bottom: var(--spacing-8); }
  .mb-4 { margin-bottom: var(--spacing-4); }
  .mt-4 { margin-top: var(--spacing-4); }
  .mt-12 { margin-top: var(--spacing-12); }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--color-text-muted);
  }
  
  .max-w-m { max-width: 700px; }
  .mx-auto { margin-left: auto; margin-right: auto; }
  .text-center { text-align: center; }

  .form-container {
    background: var(--color-bg-surface);
    padding: var(--spacing-8);
    border-radius: var(--border-radius-lg);
    box-shadow: var(--shadow-md);
    border: 1px solid var(--color-border);
  }
  
  @media (min-width: 768px) {
    .form-container { padding: var(--spacing-12); }
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-6);
  }

  .form-row {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-6);
  }
  
  @media (min-width: 600px) {
    .form-row {
      flex-direction: row;
    }
  }

  .flex-1 { flex: 1; }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
  }

  .form-group label {
    font-weight: 600;
    color: var(--color-text-main);
  }

  .input-field {
    padding: var(--spacing-3) var(--spacing-4);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-md);
    font-family: inherit;
    font-size: 1rem;
    background: var(--color-bg-base);
    transition: var(--transition-base);
  }

  .input-field:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px var(--color-primary-light);
  }

  .contact-info {
    background: var(--color-primary-light);
    padding: var(--spacing-8);
    border-radius: var(--border-radius-lg);
  }
  
  .contact-info h3 {
    margin-bottom: var(--spacing-2);
  }

  /* Honeypot — visually hidden but still in the DOM */
  .hp-field {
    position: absolute !important;
    left: -10000px !important;
    width: 1px !important;
    height: 1px !important;
    opacity: 0 !important;
    pointer-events: none !important;
  }

  .form-feedback {
    margin-top: var(--spacing-3);
    font-size: 0.95rem;
    font-weight: 500;
    min-height: 1.4rem;
    text-align: center;
  }
  .form-feedback.success { color: #15803d; }
  .form-feedback.error   { color: #b91c1c; }

  .btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
</style>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const form = document.getElementById("contact-form");
    const result = document.getElementById("contact-feedback");
    if (!form || !result) return;

    form.addEventListener("submit", function (e) {
      e.preventDefault();
      const formData = new FormData(form);
      const json = JSON.stringify(Object.fromEntries(formData));

      result.className = "form-feedback";
      result.innerHTML = "Sending…";

      fetch("https://api.web3forms.com/submit", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Accept: "application/json",
        },
        body: json,
      })
        .then(async (response) => {
          const data = await response.json();
          if (response.status === 200) {
            result.className = "form-feedback success";
            result.innerHTML = "✓ Thanks! We'll reply within one business day.";
          } else {
            console.error(response);
            result.className = "form-feedback error";
            result.innerHTML = data.message || "Something went wrong.";
          }
        })
        .catch((error) => {
          console.error(error);
          result.className = "form-feedback error";
          result.innerHTML = "Something went wrong. Please email support@samartya.com.";
        })
        .then(() => {
          form.reset();
          setTimeout(() => {
            result.innerHTML = "";
            result.className = "form-feedback";
          }, 6000);
        });
    });
  });
</script>
