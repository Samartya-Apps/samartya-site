---
import Layout from '../../layouts/Layout.astro';
---

<Layout 
  title="Request a Trial — Samartya Apps for Schools" 
  description="Request a free 30-day evaluation copy of FreeSpeech or Dyslexia Reader for your school district.">

  <section class="section section-light pt-24 pb-8">
    <div class="container max-w-m mx-auto text-center">
      <h1 class="mb-4">Evaluate Samartya Apps for Your School</h1>
      <p class="hero-subtitle">Request extended 30-day access to trial FreeSpeech, Dyslexia Reader, or both.</p>
    </div>
  </section>

  <section class="section section-light">
    <div class="container max-w-m mx-auto">
      <div class="form-container">
        <form
          id="trial-form"
          class="trial-form"
          action="https://api.web3forms.com/submit"
          method="POST"
        >
          <input type="hidden" name="access_key" value="dc5d701d-10d7-41c3-b56d-aefa709b456c" />
          <input type="hidden" name="subject" value="New school trial request — samartya.com" />
          <input type="hidden" name="from_name" value="Samartya Schools Trial Form" />
          <!-- Honeypot: humans leave it empty; bots fill it in -->
          <input type="checkbox" name="botcheck" class="hp-field" tabindex="-1" autocomplete="off" aria-hidden="true" />

          <div class="form-group">
            <label for="name">Your Name *</label>
            <input type="text" id="name" name="name" required class="input-field" autocomplete="name" />
          </div>

          <div class="form-group">
            <label for="role">Your Role *</label>
            <select id="role" name="role" required class="input-field">
              <option value="">Select your role</option>
              <option value="SLP">Speech-Language Pathologist</option>
              <option value="SpecialEducator">Special Educator</option>
              <option value="ATSpecialist">AT Specialist</option>
              <option value="Director">Director of Special Education</option>
              <option value="Other">Other</option>
            </select>
          </div>

          <div class="form-group">
            <label for="school">School or District Name *</label>
            <input type="text" id="school" name="school" required class="input-field" />
          </div>

          <div class="form-group">
            <label for="state">State *</label>
            <input type="text" id="state" name="state" required class="input-field" />
          </div>

          <div class="form-group">
            <label for="country">Country *</label>
            <input type="text" id="country" name="country" required class="input-field" value="United States of America"/>
          </div>

          <div class="form-group">
            <label for="email">Email Address *</label>
            <input type="email" id="email" name="email" required class="input-field" autocomplete="email" />
          </div>

          <div class="form-group inline-group">
            <span class="label-text">Which app(s) are you interested in?</span>
            <label class="checkbox-label"><input type="checkbox" name="apps" value="FreeSpeech"> FreeSpeech</label>
            <label class="checkbox-label"><input type="checkbox" name="apps" value="DyslexiaReader"> Dyslexia Reader</label>
            <label class="checkbox-label"><input type="checkbox" name="apps" value="Both"> Both</label>
          </div>

          <div class="form-group">
            <label for="students">How many students might use this app?</label>
            <select id="students" name="students" class="input-field">
              <option value="">Select an option</option>
              <option value="1-5">1–5</option>
              <option value="6-20">6–20</option>
              <option value="21-50">21–50</option>
              <option value="50+">50+</option>
            </select>
          </div>

          <div class="form-group">
            <label for="notes">Anything else you'd like us to know?</label>
            <textarea id="notes" name="notes" rows="4" class="input-field"></textarea>
          </div>

          <div class="form-actions">
            <button id="trial-submit" type="submit" class="btn btn-primary">Request My Free Trial</button>
          </div>

          <div id="trial-feedback" class="form-feedback" aria-live="polite"></div>

          <div class="form-note mt-6 text-sm text-center">
            We'll send your trial access within one business day. In the meantime, feel free to download FreeSpeech / Dyslexia Reader from the App Store or Google Play — the apps are free to try for 14 days.
          </div>
        </form>
      </div>
    </div>
  </section>

</Layout>

<style>
  .pt-24 { padding-top: var(--spacing-24); }
  .pb-8 { padding-bottom: var(--spacing-8); }
  .mb-4 { margin-bottom: var(--spacing-4); }
  .mt-6 { margin-top: var(--spacing-6); }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--color-text-muted);
  }
  
  .max-w-m { max-width: 700px; }
  .mx-auto { margin-left: auto; margin-right: auto; }
  .text-center { text-align: center; }
  .text-sm { font-size: 0.875rem; color: var(--color-text-muted); }

  .form-container {
    background: var(--color-bg-surface);
    padding: var(--spacing-8);
    border-radius: var(--border-radius-lg);
    box-shadow: var(--shadow-md);
    border: 1px solid var(--color-border);
  }
  
  @media (min-width: 768px) {
    .form-container { padding: var(--spacing-12); }
  }

  .trial-form {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-6);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
  }

  .form-group label, .label-text {
    font-weight: 600;
    color: var(--color-text-main);
  }

  .input-field {
    padding: var(--spacing-3) var(--spacing-4);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-md);
    font-family: inherit;
    font-size: 1rem;
    background: var(--color-bg-base);
    transition: var(--transition-base);
  }

  .input-field:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px var(--color-primary-light);
  }

  .inline-group {
    gap: var(--spacing-3);
  }
  
  .checkbox-label {
    display: flex;
    align-items: center;
    gap: var(--spacing-3);
    font-weight: normal !important;
    cursor: pointer;
  }
  
  .checkbox-label input {
    width: 1.2rem;
    height: 1.2rem;
    cursor: pointer;
  }

  .form-actions {
    margin-top: var(--spacing-4);
    display: flex;
    justify-content: center;
  }

  /* Honeypot — visually hidden but still in the DOM */
  .hp-field {
    position: absolute !important;
    left: -10000px !important;
    width: 1px !important;
    height: 1px !important;
    opacity: 0 !important;
    pointer-events: none !important;
  }

  .form-feedback {
    margin-top: var(--spacing-3);
    font-size: 0.95rem;
    font-weight: 500;
    min-height: 1.4rem;
    text-align: center;
  }
  .form-feedback.success { color: #15803d; }
  .form-feedback.error   { color: #b91c1c; }

  .btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
</style>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const form = document.getElementById("trial-form");
    const result = document.getElementById("trial-feedback");
    if (!form || !result) return;

    form.addEventListener("submit", function (e) {
      e.preventDefault();

      // Collapse the "apps" checkbox group into one comma-separated value
      // (Object.fromEntries below would otherwise keep only the last one).
      const formData = new FormData(form);
      const apps = formData.getAll("apps").map(String).filter(Boolean);
      formData.delete("apps");
      formData.append("apps", apps.length ? apps.join(", ") : "(not specified)");

      const json = JSON.stringify(Object.fromEntries(formData));

      result.className = "form-feedback";
      result.innerHTML = "Sending…";

      fetch("https://api.web3forms.com/submit", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Accept: "application/json",
        },
        body: json,
      })
        .then(async (response) => {
          const data = await response.json();
          if (response.status === 200) {
            result.className = "form-feedback success";
            result.innerHTML = "✓ Thanks! We'll be in touch within one business day.";
          } else {
            console.error(response);
            result.className = "form-feedback error";
            result.innerHTML = data.message || "Something went wrong.";
          }
        })
        .catch((error) => {
          console.error(error);
          result.className = "form-feedback error";
          result.innerHTML = "Something went wrong. Please email schools@samartya.com.";
        })
        .then(() => {
          form.reset();
          setTimeout(() => {
            result.innerHTML = "";
            result.className = "form-feedback";
          }, 6000);
        });
    });
  });
</script>
