---
// Basic Props for title and description
export interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
		
		<style>
			:root {
				--color-primary: 63, 81, 181; /* Indigo 600-700 */
			}
			body {
				font-family: system-ui, sans-serif;
				color: #333;
				background-color: #f8fafc; /* Light Gray/Off-White Background */
			}
			.text-indigo-700 { color: rgb(63, 81, 181); }
			.text-indigo-600 { color: rgb(79, 70, 229); }
			.hover\:underline:hover { text-decoration: underline; }
			.bg-indigo-600 { background-color: rgb(79, 70, 229); }
			.hover\:bg-indigo-700:hover { background-color: rgb(67, 56, 202); }
			/* A small set of utility classes for the App Cards and layout */
			.max-w-4xl { max-width: 56rem; }
			.max-w-xl { max-width: 36rem; }
			.mx-auto { margin-left: auto; margin-right: auto; }
			.p-4 { padding: 1rem; }
			.md\:p-8 { padding: 2rem; }
			.text-center { text-align: center; }
			.mb-12 { margin-bottom: 3rem; }
			.text-5xl { font-size: 3rem; line-height: 1; }
			.font-extrabold { font-weight: 800; }
			.mb-4 { margin-bottom: 1rem; }
			.text-xl { font-size: 1.25rem; line-height: 1.75rem; }
			.text-gray-600 { color: #4b5563; }
			.mb-16 { margin-bottom: 4rem; }
			.text-3xl { font-size: 1.875rem; line-height: 2.25rem; }
			.font-semibold { font-weight: 600; }
			.text-gray-800 { color: #1f2937; }
			.mb-6 { margin-bottom: 1.5rem; }
			.border-b { border-bottom-width: 1px; }
			.pb-2 { padding-bottom: 0.5rem; }
			.grid { display: grid; }
			.gap-8 { gap: 2rem; }
			@media (min-width: 768px) {
				.md\:grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
			}
			.border { border-width: 1px; border-color: #e5e7eb; }
			.rounded-lg { border-radius: 0.5rem; }
			.shadow-md { box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1); }
			.p-6 { padding: 1.5rem; }
			.bg-white { background-color: #fff; }
			.hover\:shadow-xl:hover { box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1); }
			.transition-shadow { transition-property: box-shadow; transition-duration: 300ms; }
			.flex { display: flex; }
			.items-center { align-items: center; }
			.mr-4 { margin-right: 1rem; }
			.text-2xl { font-size: 1.5rem; line-height: 2rem; }
			.font-bold { font-weight: 700; }
			.text-gray-900 { color: #111827; }
			.text-gray-700 { color: #374151; }
			.space-x-4 > * + * { margin-left: 1rem; }
			.inline-flex { display: inline-flex; }
			.px-4 { padding-left: 1rem; padding-right: 1rem; }
			.py-2 { padding-top: 0.5rem; padding-bottom: 0.5rem; }
			.shadow-sm { box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); }
			.text-sm { font-size: 0.875rem; line-height: 1.25rem; }
			.rounded-md { border-radius: 0.375rem; }
			.bg-gray-50 { background-color: #f9fafb; }
			.hover\:bg-gray-50:hover { background-color: #f9fafb; }
			.pt-8 { padding-top: 2rem; }
			.border-t { border-top-width: 1px; border-color: #e5e7eb; }
			.text-sm { font-size: 0.875rem; }
			.text-gray-500 { color: #6b7280; }
			.mt-2 { margin-top: 0.5rem; }
			.w-5 { width: 1.25rem; }
			.h-5 { height: 1.25rem; }
			.mr-2 { margin-right: 0.5rem; }
			.max-w-xl { max-width: 36rem; }
		</style>
	</head>
	<body>
		<slot />
	</body>
</html>